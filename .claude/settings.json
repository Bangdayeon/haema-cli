{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__votra-memory__start_task",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/require-task-confirmation.sh",
            "statusMessage": "사용자 확인 검사 중..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__votra-memory__finish_task",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/suggest-skill.sh",
            "statusMessage": "스킬 제안 확인 중..."
          }
        ]
      }
    ]
  }
}
