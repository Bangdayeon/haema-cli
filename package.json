{
  "name": "@haema/cli",
  "version": "0.10.0",
  "description": "haema 세션 간 연결을 위한 MCP 서버",
  "license": "MIT",
  "type": "module",
  "bin": {
    "haema": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prebuild": "rm -rf dist",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
